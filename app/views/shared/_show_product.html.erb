<div class="container py-4">
  <div class="row g-4 align-items-start text-start">
    <div class="col-12 col-md-4">
      <div class="bg-white p-3 rounded-4 shadow-sm text-center">
        <% if product.image.attached? %>
          <%= image_tag product.image, class: "img-fluid rounded-4 w-75 mx-auto d-block", alt: product.title %>
        <% else %>
          <%= image_tag "logo.png", class: "img-fluid rounded-4 w-75 mx-auto d-block", alt: product.title %>
        <% end %>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <h1 class="h3 mb-3"><%= product.title %></h1>
      <p class="text-body-secondary mb-0">Descrição do produto</p>
      <p class="mb-0"><%= product.description.presence || "Sem descrição cadastrada." %></p>
    </div>

    <div class="col-12 col-md-4">
      <div class="bg-transparent border p-3 rounded-4">
        <p class="text-body-secondary mb-1">Valor bruto</p>
        <p class="h4 fw-bold mb-2">
          R$ <%= number_with_precision(product.price, precision: 2, delimiter: ".", separator: ",") %>
        </p>

        <p class="text-body-secondary mb-2">À vista no PIX</p>

        <p class="text-body-secondary mb-4">
          ou até 12x de
          <strong>
            R$ <%= number_with_precision((product.price / 12) + 10, precision: 2, delimiter: ".", separator: ",") %>
          </strong>
        </p>

        <%= button_tag "Comprar Agora", type: "button", class: "btn btn-primary w-100" %>
      </div>
    </div>
  </div>
</div>
