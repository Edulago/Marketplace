<div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex justify-content-center mb-4">
  <div class="card product-card shadow rounded-4 h-100 w-100">
    <% if product.image.attached? %>
      <%= image_tag product.image, class: "card-img-top product-card-image", alt: product.title %>
    <% else %>
      <%= image_tag "logo.png", class: "card-img-top product-card-image", alt: product.title %>
    <% end %>
    <div class="card-body d-flex flex-column">
      <h5 class="card-title"><%= product.title %></h5>
      <p class="card-text fw-bold mt-auto">
        R$ <%= number_with_precision(product.price, precision: 2, delimiter: ".", separator: ",") %>
      </p>
      <span class="card-subtitle mb-1 text-body-secondary">
        À vista no PIX
      </span>
      <p class="card-subtitle mb-2 text-body-secondary">
        <span>ou até 12x de <%= number_with_precision((product.price / 12) + 10, precision: 2, delimiter: ".", separator: ",")%></span>
      </p>
      <%= link_to "Comprar Agora", product_path(product), class: "btn btn-primary mt-2 w-100" %>
    </div>
  </div>
</div>