<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
		<h1 class="h3 mb-0">
			<%= @selected_category.present? ? "Produtos - #{@selected_category.name}" : "Todos os produtos" %>
		</h1>
		<%= link_to "Ver todos", products_path, class: "btn btn-outline-secondary btn-sm" if @selected_category.present? %>
	</div>

	<% if @products.any? %>
		<div class="row justify-content-center">
			<%= render partial: "shared/card", collection: @products, as: :product %>
		</div>
	<% else %>
		<div class="alert alert-light border text-center">
			Nenhum produto encontrado para esta categoria.
		</div>
	<% end %>
</div>
